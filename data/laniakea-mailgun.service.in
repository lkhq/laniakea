[Unit]
Description=Laniakea Mailgun
After=network.target postgresql.service
ConditionPathExists=/etc/laniakea/mailgun.toml

[Service]
Restart=on-failure
RestartSec=15

#ProtectSystem=full
#ProtectHome=true

User=_lklighthouse
Group=_lklighthouse
ExecStart=@MAILGUN_INSTALL_BIN@

[Install]
WantedBy=multi-user.target
